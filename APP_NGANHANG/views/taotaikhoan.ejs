<h1><span style="font-size:24px; vertical-align:middle;">🔐</span> Tạo Tài Khoản (Login)</h1>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<% if (success) { %>
  <div class="alert alert-success"><%= success %></div>
<% } %>

<div style="display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px;">

    <div style="flex: 1; min-width: 350px; border: 1px solid #0d6efd; border-radius: 8px; overflow: hidden; background-color: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        <div style="background-color: #0d6efd; color: white; padding: 12px 15px; font-weight: bold; font-size: 16px;">
            <i class="fas fa-user-tie"></i> Cấp tài khoản Nhân Viên
        </div>
        <div style="padding: 20px;">
            <form action="/quantri/taotaikhoan" method="POST">
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Tìm nhân viên</label>
                    <div style="display:flex; gap:6px; margin-bottom:8px;">
                        <input type="text" id="searchNV" placeholder="Gõ mã NV hoặc họ tên..."
                               style="flex:1; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px;"
                               onkeydown="if(event.key==='Enter'){event.preventDefault();searchList('NV')}">
                        <button type="button" onclick="searchList('NV')" style="padding:8px 16px; background:#0d6efd; color:#fff; border:none; border-radius:4px; cursor:pointer; font-weight:600;">Tìm</button>
                    </div>
                    <input type="hidden" name="UserName" id="selectedNV" required>
                    <div id="resultNV" style="max-height:150px; overflow-y:auto; border:1px solid #dee2e6; border-radius:4px; display:none;">
                        <table style="width:100%; font-size:13px; margin:0;">
                            <tbody id="tbodyNV"></tbody>
                        </table>
                    </div>
                    <div id="chosenNV" style="margin-top:6px; font-weight:600; color:#0d6efd;"></div>
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Tên Đăng Nhập (Login Name)</label>
                    <input type="text" id="txtLoginNV" style="width: 100%; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px;" name="LoginName" placeholder="Ví dụ: NV01_Login" required>
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Mật khẩu (Password)</label>
                    <div style="position: relative;">
                        <input type="password" id="pwdNV" style="width: 100%; padding: 8px 36px 8px 12px; border: 1px solid #ced4da; border-radius: 4px; box-sizing: border-box;" name="Password" placeholder="Nhập mật khẩu" required>
                        <i class="fas fa-eye" id="eyeNV" onclick="toggleFormPwd('pwdNV','eyeNV')" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); cursor:pointer; color:#6c757d;"></i>
                    </div>
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Nhóm Quyền (Role)</label>
                    <% if (user.NHOM === 'NganHang') { %>
                        <select name="Role" style="width: 100%; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px; background-color: #fff;">
                            <option value="ChiNhanh" selected>ChiNhanh (Quản lý chi nhánh)</option>
                            <option value="NganHang">NganHang (Ban Giám Đốc)</option>
                        </select>
                        <small style="color: #0d6efd; display: block; margin-top: 5px; font-size: 13px;">* Ban Giám Đốc có thể cấp quyền NganHang hoặc ChiNhanh cho nhân viên.</small>
                    <% } else { %>
                        <input type="text" style="width: 100%; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px; background-color: #e9ecef; color: #495057;" name="Role" value="ChiNhanh" readonly>
                        <small style="color: #dc3545; display: block; margin-top: 5px; font-size: 13px;">* Nhân viên được gán quyền ChiNhanh (quản lý chi nhánh của mình).</small>
                    <% } %>
                </div>
                <button type="submit" style="width: 100%; padding: 10px; background-color: #0d6efd; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 15px; margin-bottom: 10px;">Tạo Tài Khoản Nhân Viên</button>
                <a href="/" style="display: block; text-align: center; width: 100%; padding: 10px; background-color: #6c757d; color: white; border: none; border-radius: 4px; font-weight: bold; text-decoration: none; font-size: 15px;">Hủy</a>
            </form>
        </div>
    </div>

    <div style="flex: 1; min-width: 350px; border: 1px solid #198754; border-radius: 8px; overflow: hidden; background-color: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
        <div style="background-color: #198754; color: white; padding: 12px 15px; font-weight: bold; font-size: 16px;">
            <i class="fas fa-user"></i> Cấp mã PIN Khách Hàng
        </div>
        <div style="padding: 20px;">
            <form action="/quantri/taotaikhoan" method="POST">
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Tìm khách hàng</label>
                    <div style="display:flex; gap:6px; margin-bottom:8px;">
                        <input type="text" id="searchKH" placeholder="Gõ CMND hoặc họ tên..."
                               style="flex:1; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px;"
                               onkeydown="if(event.key==='Enter'){event.preventDefault();searchList('KH')}">
                        <button type="button" onclick="searchList('KH')" style="padding:8px 16px; background:#198754; color:#fff; border:none; border-radius:4px; cursor:pointer; font-weight:600;">Tìm</button>
                    </div>
                    <input type="hidden" name="UserName" id="selectedKH" required>
                    <div id="resultKH" style="max-height:150px; overflow-y:auto; border:1px solid #dee2e6; border-radius:4px; display:none;">
                        <table style="width:100%; font-size:13px; margin:0;">
                            <tbody id="tbodyKH"></tbody>
                        </table>
                    </div>
                    <div id="chosenKH" style="margin-top:6px; font-weight:600; color:#198754;"></div>
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Tên Đăng Nhập</label>
                    <input type="text" style="width: 100%; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px; background-color: #e9ecef; color: #495057;" id="txtLoginKH" name="LoginName" readonly required>
                    <small style="color: #198754; display: block; margin-top: 5px; font-size: 13px;">* Tên đăng nhập được cố định là số CMND.</small>
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Mật khẩu (Mã PIN)</label>
                    <div style="position: relative;">
                        <input type="password" id="pwdKH" style="width: 100%; padding: 8px 36px 8px 12px; border: 1px solid #ced4da; border-radius: 4px; box-sizing: border-box;" name="Password" placeholder="Nhập mã PIN 6 số..." required>
                        <i class="fas fa-eye" id="eyeKH" onclick="toggleFormPwd('pwdKH','eyeKH')" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); cursor:pointer; color:#6c757d;"></i>
                    </div>
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Nhóm Quyền (Role)</label>
                    <input type="text" style="width: 100%; padding: 8px 12px; border: 1px solid #ced4da; border-radius: 4px; background-color: #e9ecef; color: #495057;" name="Role" value="KhachHang" readonly>
                    <small style="color: #198754; display: block; margin-top: 5px; font-size: 13px;">* Hệ thống tự động giới hạn quyền tra cứu.</small>
                </div>
                <button type="submit" style="width: 100%; padding: 10px; background-color: #198754; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; font-size: 15px; margin-bottom: 10px;">Cấp Quyền Khách Hàng</button>
                <a href="/" style="display: block; text-align: center; width: 100%; padding: 10px; background-color: #6c757d; color: white; border: none; border-radius: 4px; font-weight: bold; text-decoration: none; font-size: 15px;">Hủy</a>
            </form>
        </div>
    </div>

</div>

<div style="margin-top: 30px; border: 1px solid #ced4da; border-radius: 8px; overflow: hidden; background-color: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
    <div style="background-color: #343a40; color: white; padding: 12px 15px; font-weight: bold; font-size: 16px;">
        <i class="fas fa-list"></i> Danh sách trạng thái Tài khoản
    </div>
    <div style="padding: 20px; overflow-x: auto;">
        <div style="display: flex; flex-wrap: wrap; gap: 15px; margin-bottom: 15px; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <label style="font-weight: 600; white-space: nowrap;">Loại:</label>
                <select id="filterLoai" onchange="applyTableFilter()" style="padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px; min-width: 140px;">
                    <option value="">Tất cả</option>
                    <option value="NhanVien">Nhân viên</option>
                    <option value="KhachHang">Khách hàng</option>
                </select>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <label style="font-weight: 600; white-space: nowrap;">Trạng thái:</label>
                <select id="filterTrangThai" onchange="applyTableFilter()" style="padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px; min-width: 140px;">
                    <option value="">Tất cả</option>
                    <option value="1">Đã cấp</option>
                    <option value="0">Chưa cấp</option>
                    <option value="2">Lỗi đồng bộ</option>
                </select>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
                <label style="font-weight: 600; white-space: nowrap;">Tìm kiếm:</label>
                <input type="text" id="filterSearch" oninput="applyTableFilter()" placeholder="Mã, họ tên, login..."
                       style="padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px; min-width: 200px;">
            </div>
        </div>
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Loại</th>
                    <th>Mã (MANV/CMND)</th>
                    <th>Họ Tên</th>
                    <th>Chi nhánh</th>
                    <th>Trạng thái</th>
                    <th>Login Name</th>
                    <th>Nhóm Quyền</th>
                    <% if (user.NHOM === 'NganHang') { %>
                        <th>Mật khẩu</th>
                    <% } %>
                    <th>Ngày cập nhật</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="login-status-tbody">
                <!-- JS sẽ render dòng vào đây -->
            </tbody>
        </table>
    </div>
</div>

<script>
let allLoginData = [];

async function loadLoginStatusTable() {
  const tbody = document.getElementById('login-status-tbody');
  tbody.innerHTML = '<tr><td colspan="9" style="text-align:center; padding:20px;">Đang tải dữ liệu...</td></tr>';

  try {
    const res = await fetch('/quantri/login-management/list');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const data = await res.json();

    if (!data || data.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" style="text-align:center; padding:20px;">Không có dữ liệu</td></tr>';
      return;
    }

    allLoginData = data;
    renderLoginRows(data);
  } catch (err) {
    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center; padding:20px; color:#dc2626;">Lỗi tải dữ liệu: ${err.message}</td></tr>`;
  }
}

function renderLoginRows(data) {
    const tbody = document.getElementById('login-status-tbody');
    const isNganHang = '<%= user.NHOM %>' === 'NganHang';

    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9" style="text-align:center; padding:20px;">Không có dữ liệu phù hợp</td></tr>';
        return;
    }

    tbody.innerHTML = data.map(row => {
      let actionHtml = '';
      let passHtml = '';

      if (row.DaCapTaiKhoan === 1) {
          if (isNganHang) {
              actionHtml = `<button class="btn btn-sm" style="background:#f59e0b; color:#fff; border:none; margin-right:4px;" onclick="resetPassword('${row.LoginName}', '${row.HoTen}')"><i class="fas fa-key"></i> Reset MK</button>`
                + (row.LoginName !== 'admin' ? `<button class="btn btn-sm" style="background:#7c3aed; color:#fff; border:none;" onclick="changeRole('${row.LoginName}', '${row.HoTen}', '${row.NhomQuyen}')"><i class="fas fa-exchange-alt"></i> Đổi nhóm</button>` : '');
              passHtml = `
                  <td>
                      <span id="pass_${row.LoginName}">******</span>
                      <i class="fas fa-eye" style="cursor: pointer; margin-left: 5px; color: #0d6efd;" onclick="togglePassword('${row.LoginName}')"></i>
                  </td>
              `;
          } else {
              actionHtml = `<span class="text-muted">Không có quyền</span>`;
          }
      } else if (row.DaCapTaiKhoan === 2) {
          // Lỗi đồng bộ: có trong QuanTriLogin nhưng login đã bị xóa khỏi SQL Server
          const canRecreate = isNganHang || row.LoaiTK === 'KhachHang';
          if (canRecreate) {
              actionHtml = `<button class="btn btn-sm" style="background:#dc2626; color:#fff; border:none;" onclick="cleanupAndRecreate('${row.LoginName}', '${row.MaThamChieu}', '${row.LoaiTK}')"><i class="fas fa-redo"></i> Tạo lại</button>`;
              passHtml = isNganHang ? `<td><span style="color:#dc2626;">— lỗi —</span></td>` : '';
          } else {
              actionHtml = `<span class="text-muted">Không có quyền</span>`;
              passHtml = isNganHang ? `<td>—</td>` : '';
          }
      } else {
          actionHtml = `<button class="btn btn-sm" style="background:#2563eb; color:#fff; border:none;" onclick="prefillForm('${row.LoaiTK}', '${row.MaThamChieu}')"><i class="fas fa-plus"></i> Cấp TK</button>`;
          if (isNganHang) {
              passHtml = `<td>—</td>`;
          }
      }

        const rawDate = row.NgayCapNhatMK || row.NgayTao;
        let dateHtml = '—';
        if (rawDate) {
            const datePart = rawDate.substring(0, 10);
            const parts = datePart.split('-');
            if (parts.length === 3) {
                dateHtml = `${parts[2]}/${parts[1]}/${parts[0]}`;
            }
        }

      return `
      <tr>
        <td>
          <span style="background:${row.LoaiTK === 'NhanVien' ? '#2563eb' : '#16a34a'}; color:#fff; padding:2px 8px; border-radius:4px; font-size:12px; font-weight:600;">
            ${row.LoaiTK === 'NhanVien' ? 'NHÂN VIÊN' : 'KHÁCH HÀNG'}
          </span>
        </td>
        <td>${row.MaThamChieu || ''}</td>
        <td>${row.HoTen || ''}</td>
        <td>${row.MACN || ''}</td>
        <td>
          ${row.DaCapTaiKhoan === 1
            ? '<span style="color:#16a34a; font-weight:600;">● Đã cấp</span>'
            : row.DaCapTaiKhoan === 2
              ? '<span style="color:#dc2626; font-weight:600;">⚠ Lỗi đồng bộ</span>'
              : '<span style="color:#6b7280; font-weight:600;">● Chưa cấp</span>'}
        </td>
        <td>${row.LoginName || '—'}</td>
        <td>${row.NhomQuyen || '—'}</td>
        ${isNganHang ? passHtml : ''}
        <td>${dateHtml}</td>
        <td>${actionHtml}</td>
      </tr>
      `;
    }).join('');
}

document.addEventListener('DOMContentLoaded', loadLoginStatusTable);

function applyTableFilter() {
    const loai = document.getElementById('filterLoai').value;
    const trangThai = document.getElementById('filterTrangThai').value;
    const search = document.getElementById('filterSearch').value.toLowerCase().normalize('NFC');

    const filtered = allLoginData.filter(row => {
        if (loai && row.LoaiTK !== loai) return false;
        if (trangThai !== '' && String(row.DaCapTaiKhoan) !== trangThai) return false;
        if (search) {
            const haystack = [row.MaThamChieu, row.HoTen, row.LoginName, row.MACN, row.NhomQuyen]
                .filter(Boolean).join(' ').toLowerCase().normalize('NFC');
            if (!haystack.includes(search)) return false;
        }
        return true;
    });

    renderLoginRows(filtered);
}

function togglePassword(loginName) {
    const span = document.getElementById('pass_' + loginName);
    if (span.innerText.trim() === '******') {
        fetch('/quantri/login-management/password/' + loginName)
            .then(res => {
                if(!res.ok) throw new Error('Không có quyền hoặc lỗi API');
                return res.json();
            })
            .then(data => {
                span.innerText = data.password;
            })
            .catch(err => alert(err.message));
    } else {
        span.innerText = '******';
    }
}

function resetPassword(loginName, hoTen) {
    if (confirm(`Đặt lại mật khẩu về mặc định (123456) cho tài khoản của ${hoTen} (${loginName})?`)) {
        fetch('/quantri/login-management/reset-password', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ loginName: loginName })
        })
        .then(res => res.json())
        .then(data => {
            if(data.success) {
                alert(data.message);
                loadLoginStatusTable();
            } else {
                alert('Lỗi: ' + data.error);
            }
        })
        .catch(err => alert("Lỗi khi gọi API: " + err.message));
    }
}

function changeRole(loginName, hoTen, currentRole) {
    const roles = ['NganHang', 'ChiNhanh', 'KhachHang'].filter(r => r !== currentRole.trim());
    const newRole = prompt(`Đổi nhóm quyền cho ${hoTen} (${loginName}).\nHiện tại: ${currentRole}\n\nChọn nhóm mới:\n1. ${roles[0]}\n2. ${roles[1]}\n\nNhập 1 hoặc 2:`);
    if (!newRole) return;
    const selected = newRole === '1' ? roles[0] : newRole === '2' ? roles[1] : null;
    if (!selected) { alert('Lựa chọn không hợp lệ.'); return; }
    if (!confirm(`Xác nhận đổi nhóm quyền:\n${hoTen} (${loginName})\n${currentRole} → ${selected}`)) return;

    fetch('/quantri/login-management/change-role', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ loginName, newRole: selected })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) { alert(data.message); loadLoginStatusTable(); }
        else alert('Lỗi: ' + data.error);
    })
    .catch(err => alert('Lỗi kết nối: ' + err.message));
}

function cleanupAndRecreate(loginName, maThamChieu, loaiTK) {
    if (!confirm(`Tài khoản "${loginName}" bị lỗi đồng bộ (login không tồn tại trên server).\nBấm OK để xóa dữ liệu cũ và cho phép tạo lại.`)) return;

    fetch('/quantri/login-management/cleanup-sync-error', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ loginName: loginName, userName: maThamChieu })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            loadLoginStatusTable();
            prefillForm(loaiTK, maThamChieu);
        } else {
            alert('Lỗi khi dọn dẹp: ' + data.error);
        }
    })
    .catch(err => alert('Lỗi kết nối: ' + err.message));
}

function toggleFormPwd(inputId, iconId) {
    const inp = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (inp.type === 'password') {
        inp.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        inp.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}

const allNV = [
    <% if(typeof nhanviens !== 'undefined') { nhanviens.forEach(nv => { %>
    { value: '<%= nv.MANV %>', text: '<%= nv.MANV %> - <%= nv.HO %> <%= nv.TEN %><%= nv.MACN ? " [" + nv.MACN + "]" : "" %>' },
    <% }) } %>
];
const allKH = [
    <% if(typeof khachhangs !== 'undefined') { khachhangs.forEach(kh => { %>
    { value: '<%= kh.CMND %>', text: '<%= kh.CMND %> - <%= kh.HO %> <%= kh.TEN %>' },
    <% }) } %>
];

function searchList(type) {
    const kw = document.getElementById('search' + type).value.toLowerCase().normalize('NFC');
    const list = type === 'NV' ? allNV : allKH;
    const tbody = document.getElementById('tbody' + type);
    const container = document.getElementById('result' + type);

    const filtered = kw ? list.filter(r => r.text.toLowerCase().normalize('NFC').includes(kw)) : list;

    if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td style="padding:8px; text-align:center; color:#999;">Không tìm thấy</td></tr>';
    } else {
        tbody.innerHTML = filtered.map(r =>
            `<tr style="cursor:pointer;" onmouseover="this.style.background='#e8f0fe'" onmouseout="this.style.background=''" onclick="pickItem('${type}','${r.value}','${r.text.replace(/'/g,"\\'")}')">
                <td style="padding:6px 10px;">${r.text}</td>
            </tr>`
        ).join('');
    }
    container.style.display = 'block';
}

function pickItem(type, value, text) {
    document.getElementById('selected' + type).value = value;
    document.getElementById('chosen' + type).textContent = '✓ Đã chọn: ' + text;
    document.getElementById('result' + type).style.display = 'none';
    if (type === 'KH') {
        const loginKH = document.getElementById('txtLoginKH');
        if (loginKH) loginKH.value = value;
    }
}

function prefillForm(loaiTK, maThamChieu) {
    if (loaiTK === 'NhanVien') {
        const item = allNV.find(r => r.value === maThamChieu);
        if (item) pickItem('NV', item.value, item.text);
        const loginField = document.getElementById('txtLoginNV');
        const pwdField = document.getElementById('pwdNV');
        if (loginField) loginField.value = '';
        if (pwdField) pwdField.value = '';
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (loginField) loginField.focus();
    } else {
        const item = allKH.find(r => r.value === maThamChieu);
        if (item) pickItem('KH', item.value, item.text);
        const pwdField = document.getElementById('pwdKH');
        if (pwdField) pwdField.value = '';
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (pwdField) pwdField.focus();
    }
}
</script>
